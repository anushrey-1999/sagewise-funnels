{
  "id": "mortgage",
  "title": "Sagewise Mortgage Finder",
  "subtitle": "Compare rates from 100+ top lenders and find your best match.",
  "metaDescription": "Find the best mortgage rates for 2026. Compare loans from 100+ lenders for buying a home, refinancing, or cash-out options.",
  "finalStep": {
    "buttonText": "Get My Rates",
    "loaderText": "Searching 100+ top lenders... Finding your best matches...",
    "disclaimerText": "By clicking on the view results button above, I consent, acknowledge, and agree to our <a href=\"https://sagewise.net/terms-of-use/\" target=\"_blank\" rel=\"noopener noreferrer\">Terms of Use Agreement</a> and <a href=\"https://sagewise.net/privacy-policy/\" target=\"_blank\" rel=\"noopener noreferrer\">Privacy Policy</a>, and I am providing my ESIGN/electronic signature and express written consent agreement to permit the selected lenders, and parties calling on their behalf to contact me at the number provided on this page for marketing purposes relating to these companies' mortgages and other products, services, and financing, including through the use of automated dialing technology, AI generated/prerecorded/artificial voice, SMS/MMS text, even if my number is on any internal, federal or state Do Not Call registry list."
  },
  "steps": [
    {
      "id": "loan-type",
      "title": "What type of loan are you looking for?",
      "description": "Your answer helps us personalize your rate results.",
      "fields": [
        {
          "id": "loanType",
          "type": "radio",
          "label": "",
          "required": true,
          "autoForward": true,
          "options": [
            { "value": "home-equity-heloc", "label": "Access My Equity" },
            { "value": "refinance", "label": "Lower My Rate" },
            { "value": "purchase", "label": "Buy a Home" }
          ],
          "redirectOnAnswer": {
            "rules": [
              { "whenValues": ["home-equity-heloc"], "to": "/adwall/mortgage/heloc" },
              { "whenValues": ["refinance"], "to": "/adwall/mortgage/refi" },
              { "whenValues": ["purchase"], "to": "/adwall/mortgage/purchase" }
            ]
          }
        }
      ]
    },

    {
      "id": "refinance-goal",
      "title": "What will you use your equity for?",
      "description": "Different uses may qualify for different rates and terms.",
      "skipIf": {
        "checkStepId": "loan-type",
        "checkFieldId": "loanType",
        "whenValues": ["home-equity-heloc", "purchase"]
      },
      "fields": [
        {
          "id": "refinanceGoal",
          "type": "radio",
          "label": "",
          "required": true,
          "autoForward": true,
          "options": [
            { "value": "lower-rate", "label": "Lower my rate" },
            { "value": "lower-payment", "label": "Lower my payment" },
            { "value": "cash-out", "label": "Cash out" },
            { "value": "shorten-term", "label": "Shorten my term" }
          ]
        }
      ]
    },

    {
      "id": "purchase-timeline",
      "title": "When are you looking to buy?",
      "description": "Helps us find the right timing for your rates.",
      "skipIf": {
        "checkStepId": "loan-type",
        "checkFieldId": "loanType",
        "whenValues": ["home-equity-heloc", "refinance"]
      },
      "fields": [
        {
          "id": "purchaseTimeline",
          "type": "radio",
          "label": "",
          "required": true,
          "autoForward": true,
          "options": [
            { "value": "asap", "label": "ASAP" },
            { "value": "3-months", "label": "Within 3 months" },
            { "value": "6-months", "label": "Within 6 months" },
            { "value": "researching", "label": "Just researching" }
          ]
        }
      ]
    },

    {
      "id": "first-time-buyer",
      "title": "Are you a first-time home buyer?",
      "description": "First-time buyers may qualify for special programs.",
      "skipIf": {
        "checkStepId": "loan-type",
        "checkFieldId": "loanType",
        "whenValues": ["home-equity-heloc", "refinance"]
      },
      "fields": [
        {
          "id": "firstTimeBuyer",
          "type": "radio",
          "label": "",
          "required": true,
          "autoForward": true,
          "options": [
            { "value": "yes", "label": "Yes" },
            { "value": "no", "label": "No" }
          ]
        }
      ]
    },

    {
      "id": "property-type",
      "title": "What type of property is this for?",
      "description": "Different property types qualify for different programs.",
      "fields": [
        {
          "id": "propertyType",
          "type": "radio",
          "label": "",
          "required": true,
          "options": [
            { "value": "single-family", "label": "Single-Family" },
            { "value": "multifamily", "label": "Multifamily" },
            { "value": "condo-townhome", "label": "Condo/Townhome" },
            { "value": "manufactured", "label": "Manufactured" }
          ]
        }
      ]
    },

    {
      "id": "zip-code-refi-purchase",
      "title": "Where are you located?",
      "description": "Rates vary by location — we'll find what's available near you.",
      "skipIf": {
        "checkStepId": "loan-type",
        "checkFieldId": "loanType",
        "whenValues": ["home-equity-heloc"]
      },
      "fields": [
        {
          "id": "zipCode",
          "type": "text",
          "label": "Zip code",
          "placeholder": "12345",
          "required": true,
          "autoForward": true,
          "validation": {
            "pattern": "^[0-9]{5}$",
            "message": "Please enter a valid 5-digit zip code."
          }
        }
      ]
    },

    {
      "id": "property-use",
      "title": "How do you use this property?",
      "description": "Primary homes often qualify for the lowest available rates.",
      "skipIf": {
        "checkStepId": "loan-type",
        "checkFieldId": "loanType",
        "whenValues": ["purchase"]
      },
      "fields": [
        {
          "id": "propertyUse",
          "type": "radio",
          "label": "",
          "required": true,
          "autoForward": true,
          "options": [
            { "value": "primary", "label": "Primary Residence" },
            { "value": "secondary", "label": "Secondary / Vacation Home" },
            { "value": "investment", "label": "Investment Property" }
          ]
        }
      ]
    },

    {
      "id": "zip-code-heloc",
      "title": "Where are you located?",
      "description": "Rates vary by location — we'll find what's available near you.",
      "skipIf": {
        "checkStepId": "loan-type",
        "checkFieldId": "loanType",
        "whenValues": ["refinance", "purchase"]
      },
      "fields": [
        {
          "id": "zipCode",
          "type": "text",
          "label": "Zip code",
          "placeholder": "12345",
          "required": true,
          "autoForward": true,
          "validation": {
            "pattern": "^[0-9]{5}$",
            "message": "Please enter a valid 5-digit zip code."
          }
        }
      ]
    },

    {
      "id": "home-value",
      "title": "Estimated home value?",
      "description": "Take your best guess — it's okay to estimate.",
      "skipIf": {
        "checkStepId": "loan-type",
        "checkFieldId": "loanType",
        "whenValues": ["purchase"]
      },
      "fields": [
        {
          "id": "homeValue",
          "type": "slider",
          "label": "",
          "defaultValue": 400000,
          "required": true,
          "validation": {
            "min": 50000,
            "max": 2000000
          }
        }
      ]
    },

    {
      "id": "mortgage-balance",
      "title": "Current loan balance?",
      "description": "Helps us calculate your available equity.",
      "skipIf": {
        "checkStepId": "loan-type",
        "checkFieldId": "loanType",
        "whenValues": ["purchase"]
      },
      "fields": [
        {
          "id": "mortgageBalance",
          "type": "slider",
          "label": "",
          "defaultValue": 200000,
          "required": true,
          "validation": {
            "min": 0,
            "max": 2000000
          }
        }
      ]
    },

    {
      "id": "equity-display",
      "title": "Here's what you could access.",
      "description": "Based on what you've shared, here's your potential borrowing power.",
      "skipIf": {
        "checkStepId": "loan-type",
        "checkFieldId": "loanType",
        "whenValues": ["refinance", "purchase"]
      },
      "fields": [
        {
          "id": "equityAck",
          "type": "radio",
          "label": "",
          "required": false,
          "autoForward": false,
          "options": []
        }
      ]
    },

    {
      "id": "heloc-loan-purpose",
      "title": "What will you use your equity for?",
      "description": "Different uses may qualify for different rates and terms.",
      "skipIf": {
        "checkStepId": "loan-type",
        "checkFieldId": "loanType",
        "whenValues": ["refinance", "purchase"]
      },
      "fields": [
        {
          "id": "helocPurpose",
          "type": "radio",
          "label": "",
          "required": true,
          "autoForward": true,
          "options": [
            { "value": "debt-consolidation", "label": "Debt Consolidation" },
            { "value": "home-improvement", "label": "Home Improvement" },
            { "value": "emergency", "label": "Emergency Expenses" },
            { "value": "investment", "label": "Investment" },
            { "value": "other", "label": "Other" }
          ]
        }
      ]
    },

    {
      "id": "purchase-price",
      "title": "Estimated purchase price?",
      "description": "Helps match you with the right loan amount options.",
      "skipIf": {
        "checkStepId": "loan-type",
        "checkFieldId": "loanType",
        "whenValues": ["home-equity-heloc", "refinance"]
      },
      "fields": [
        {
          "id": "purchasePrice",
          "type": "slider",
          "label": "",
          "defaultValue": 350000,
          "required": true,
          "validation": {
            "min": 50000,
            "max": 2000000
          }
        }
      ]
    },

    {
      "id": "down-payment",
      "title": "Planned down payment?",
      "description": "Lower down payments may still qualify for competitive rates.",
      "skipIf": {
        "checkStepId": "loan-type",
        "checkFieldId": "loanType",
        "whenValues": ["home-equity-heloc", "refinance"]
      },
      "fields": [
        {
          "id": "downPayment",
          "type": "radio",
          "label": "",
          "required": true,
          "autoForward": true,
          "options": [
            { "value": "3.5", "label": "3.5%" },
            { "value": "5", "label": "5%" },
            { "value": "10", "label": "10%" },
            { "value": "20", "label": "20%" },
            { "value": "other", "label": "Other" }
          ]
        }
      ]
    },

    {
      "id": "current-interest-rate",
      "title": "Current interest rate?",
      "description": "We'll compare this to today's rates to show your potential savings.",
      "skipIf": {
        "checkStepId": "loan-type",
        "checkFieldId": "loanType",
        "whenValues": ["home-equity-heloc", "purchase"]
      },
      "fields": [
        {
          "id": "currentInterestRate",
          "type": "slider",
          "label": "",
          "defaultValue": 6.9,
          "required": true,
          "validation": {
            "min": 1,
            "max": 15
          }
        }
      ]
    },

    {
      "id": "credit-score",
      "title": "Estimated credit score?",
      "description": "Checking won't impact your score.",
      "fields": [
        {
          "id": "creditScore",
          "type": "radio",
          "label": "",
          "required": true,
          "options": [
            { "value": "excellent", "label": "Excellent (740+)" },
            { "value": "good", "label": "Good (680-739)" },
            { "value": "fair", "label": "Fair (620-679)" },
            { "value": "poor", "label": "Poor (Below 620)" }
          ]
        }
      ]
    },

    {
      "id": "employment-status",
      "title": "What's your employment status?",
      "description": "Helps lenders determine your qualifying loan options.",
      "skipIf": {
        "checkStepId": "loan-type",
        "checkFieldId": "loanType",
        "whenValues": ["home-equity-heloc"]
      },
      "fields": [
        {
          "id": "employmentStatus",
          "type": "radio",
          "label": "",
          "required": true,
          "autoForward": true,
          "options": [
            { "value": "employed", "label": "Employed" },
            { "value": "self-employed", "label": "Self-Employed" },
            { "value": "retired", "label": "Retired" },
            { "value": "unemployed", "label": "Unemployed" }
          ]
        }
      ]
    },

    {
      "id": "contact",
      "title": "Ready to see your matches?",
      "description": "Your data is safe and secure. Match Engine",
      "fields": [
        {
          "id": "firstName",
          "type": "text",
          "label": "First Name",
          "placeholder": "John",
          "required": true
        },
        {
          "id": "lastName",
          "type": "text",
          "label": "Last Name",
          "placeholder": "Doe",
          "required": true
        },
        {
          "id": "email",
          "type": "email",
          "label": "Email",
          "placeholder": "john.doe@email.com",
          "required": true
        }
      ]
    }
  ]
}
