{
  "id": "mortgage",
  "title": "Sagewise Mortgage Finder",
  "subtitle": "Compare rates from 100+ top lenders and find your best match.",
  "metaDescription": "Find the best mortgage rates for 2026. Compare loans from 100+ lenders for buying a home, refinancing, or cash-out options.",
  "finalStep": {
    "buttonText": "SEE MATCHES",
    "loaderText": "Searching 100+ top lenders... Finding your best matches...",
    "disclaimerText": "By pressing \"SEE MATCHES\" you agree to our privacy policy and consent to have an agent from one of our partners contact you by email, phone call, and/or text/SMS at the phone number and email you provide. Consent isn't a condition to purchase products."
  },
  "steps": [
    {
      "id": "zip-code",
      "title": "Enter your Zip Code",
      "description": "",
      "fields": [
        {
          "id": "zipCode",
          "type": "text",
          "label": "",
          "placeholder": "5-Digit Number",
          "required": true,
          "autoForward": true,
          "validation": {
            "pattern": "^[0-9]{5}$",
            "message": "Please enter a valid 5-digit zip code"
          }
        }
      ]
    },
    {
      "id": "loan-type",
      "title": "What type of loan are you looking for?",
      "description": "We'll match you with the best options.",
      "fields": [
        {
          "id": "loanType",
          "type": "radio",
          "label": "",
          "required": true,
          "autoForward": true,
          "options": [
            { "value": "home-equity-heloc", "label": "Tap into your home's equity" },
            { "value": "refinance", "label": "Lower my rate or payment" },
            { "value": "purchase", "label": "Buy a new home" },
            { "value": "cash-out-refinance", "label": "Access cash from my home" }
          ],
          "redirectOnAnswer": {
            "rules": [
              { "whenValues": ["home-equity-heloc"], "to": "/adwall/mortgage/heloc" },
              { "whenValues": ["refinance"], "to": "/adwall/mortgage/refi" },
              { "whenValues": ["purchase"], "to": "/adwall/mortgage/purchase" },
              { "whenValues": ["cash-out-refinance"], "to": "/adwall/mortgage/heloc" }
            ]
          }
        }
      ]
    },

    {
      "id": "refinance-goal",
      "title": "What's your refinance goal?",
      "description": "We'll tailor your results.",
      "skipIf": {
        "checkStepId": "loan-type",
        "checkFieldId": "loanType",
        "whenValues": ["home-equity-heloc", "purchase", "cash-out-refinance"]
      },
      "fields": [
        {
          "id": "refinanceGoal",
          "type": "radio",
          "label": "",
          "required": true,
          "autoForward": true,
          "options": [
            { "value": "lower-rate", "label": "Lower my rate" },
            { "value": "lower-payment", "label": "Lower my payment" },
            { "value": "cash-out", "label": "Cash out" },
            { "value": "shorten-term", "label": "Shorten my term" }
          ]
        }
      ]
    },

    {
      "id": "purchase-timeline",
      "title": "When are you looking to buy?",
      "description": "Helps us find the right timing for your rates.",
      "skipIf": {
        "checkStepId": "loan-type",
        "checkFieldId": "loanType",
        "whenValues": ["home-equity-heloc", "refinance", "cash-out-refinance"]
      },
      "fields": [
        {
          "id": "purchaseTimeline",
          "type": "radio",
          "label": "",
          "required": true,
          "autoForward": true,
          "options": [
            { "value": "asap", "label": "ASAP" },
            { "value": "3-months", "label": "Within 3 months" },
            { "value": "6-months", "label": "Within 6 months" },
            { "value": "researching", "label": "Just researching" }
          ]
        }
      ]
    },

    {
      "id": "first-time-buyer",
      "title": "Are you a first-time home buyer?",
      "description": "First-time buyers may qualify for special programs.",
      "skipIf": {
        "checkStepId": "loan-type",
        "checkFieldId": "loanType",
        "whenValues": ["home-equity-heloc", "refinance", "cash-out-refinance"]
      },
      "fields": [
        {
          "id": "firstTimeBuyer",
          "type": "radio",
          "label": "",
          "required": true,
          "autoForward": true,
          "options": [
            { "value": "yes", "label": "Yes" },
            { "value": "no", "label": "No" }
          ]
        }
      ]
    },

    {
      "id": "property-type",
      "title": "What type of property is this for?",
      "description": "Property type affects your final rate.",
      "fields": [
        {
          "id": "propertyType",
          "type": "radio",
          "label": "",
          "required": true,
          "options": [
            { "value": "single-family", "label": "Single-Family" },
            { "value": "multifamily", "label": "Multifamily" },
            { "value": "condo-townhome", "label": "Condo/Townhome" },
            { "value": "manufactured", "label": "Manufactured" }
          ]
        }
      ]
    },

    {
      "id": "property-use",
      "title": "How do you use this property?",
      "description": "This helps determine your rate options.",
      "skipIf": {
        "checkStepId": "loan-type",
        "checkFieldId": "loanType",
        "whenValues": ["purchase", "cash-out-refinance"]
      },
      "fields": [
        {
          "id": "propertyUse",
          "type": "radio",
          "label": "",
          "required": true,
          "autoForward": true,
          "options": [
            { "value": "primary", "label": "Primary Residence" },
            { "value": "secondary", "label": "Secondary / Vacation Home" },
            { "value": "investment", "label": "Investment Property" }
          ]
        }
      ]
    },

    {
      "id": "home-value",
      "title": "Estimated home value?",
      "description": "Take your best guess — it's okay to estimate.",
      "skipIf": {
        "checkStepId": "loan-type",
        "checkFieldId": "loanType",
        "whenValues": ["purchase"]
      },
      "fields": [
        {
          "id": "homeValue",
          "type": "slider",
          "label": "",
          "required": true,
          "validation": {
            "min": 50000,
            "max": 2000000
          }
        }
      ]
    },

    {
      "id": "mortgage-balance",
      "title": "Current loan balance?",
      "description": "It's okay to estimate.",
      "skipIf": {
        "checkStepId": "loan-type",
        "checkFieldId": "loanType",
        "whenValues": ["purchase"]
      },
      "fields": [
        {
          "id": "mortgageBalance",
          "type": "slider",
          "label": "",
          "required": true,
          "validation": {
            "min": 0,
            "max": 2000000
          }
        }
      ]
    },

    {
      "id": "equity-display",
      "title": "Your estimated available equity",
      "description": "Calculated as your home value minus your mortgage balance.",
      "skipIf": {
        "checkStepId": "loan-type",
        "checkFieldId": "loanType",
        "whenValues": ["refinance", "purchase", "cash-out-refinance"]
      },
      "fields": [
        {
          "id": "equityAck",
          "type": "radio",
          "label": "",
          "required": false,
          "autoForward": false,
          "options": []
        }
      ]
    },

    {
      "id": "heloc-loan-purpose",
      "title": "What do you plan to use the funds for?",
      "description": "Helps us find the right program for you.",
      "skipIf": {
        "checkStepId": "loan-type",
        "checkFieldId": "loanType",
        "whenValues": ["refinance", "purchase", "cash-out-refinance"]
      },
      "fields": [
        {
          "id": "helocPurpose",
          "type": "radio",
          "label": "",
          "required": true,
          "autoForward": true,
          "options": [
            { "value": "debt-consolidation", "label": "Debt Consolidation" },
            { "value": "home-improvement", "label": "Home Improvement" },
            { "value": "emergency", "label": "Emergency Expenses" },
            { "value": "investment", "label": "Investment" },
            { "value": "other", "label": "Other" }
          ]
        }
      ]
    },

    {
      "id": "desired-cash-amount",
      "title": "How much cash do you need?",
      "description": "It's okay to estimate.",
      "skipIf": {
        "checkStepId": "loan-type",
        "checkFieldId": "loanType",
        "whenValues": ["home-equity-heloc", "refinance", "purchase"]
      },
      "fields": [
        {
          "id": "desiredCashAmount",
          "type": "slider",
          "label": "",
          "required": true,
          "validation": {
            "min": 10000,
            "max": 500000
          }
        }
      ]
    },

    {
      "id": "cashout-purpose",
      "title": "What will you use the cash for?",
      "description": "Helps us match the best program.",
      "skipIf": {
        "checkStepId": "loan-type",
        "checkFieldId": "loanType",
        "whenValues": ["home-equity-heloc", "refinance", "purchase"]
      },
      "fields": [
        {
          "id": "cashoutPurpose",
          "type": "radio",
          "label": "",
          "required": true,
          "autoForward": true,
          "options": [
            { "value": "debt-consolidation", "label": "Debt Consolidation" },
            { "value": "home-improvement", "label": "Home Improvement" },
            { "value": "emergency", "label": "Emergency Expenses" },
            { "value": "other", "label": "Other" }
          ]
        }
      ]
    },

    {
      "id": "purchase-price",
      "title": "Estimated purchase price?",
      "description": "It's okay to estimate.",
      "skipIf": {
        "checkStepId": "loan-type",
        "checkFieldId": "loanType",
        "whenValues": ["home-equity-heloc", "refinance", "cash-out-refinance"]
      },
      "fields": [
        {
          "id": "purchasePrice",
          "type": "slider",
          "label": "",
          "required": true,
          "validation": {
            "min": 50000,
            "max": 2000000
          }
        }
      ]
    },

    {
      "id": "down-payment",
      "title": "Planned down payment?",
      "description": "Select a percentage or enter a custom amount.",
      "skipIf": {
        "checkStepId": "loan-type",
        "checkFieldId": "loanType",
        "whenValues": ["home-equity-heloc", "refinance", "cash-out-refinance"]
      },
      "fields": [
        {
          "id": "downPayment",
          "type": "radio",
          "label": "",
          "required": true,
          "autoForward": true,
          "options": [
            { "value": "3.5", "label": "3.5%" },
            { "value": "5", "label": "5%" },
            { "value": "10", "label": "10%" },
            { "value": "20", "label": "20%" },
            { "value": "other", "label": "Other" }
          ]
        }
      ]
    },

    {
      "id": "current-interest-rate",
      "title": "Current interest rate?",
      "description": "Your best estimate is fine.",
      "skipIf": {
        "checkStepId": "loan-type",
        "checkFieldId": "loanType",
        "whenValues": ["home-equity-heloc", "purchase", "cash-out-refinance"]
      },
      "fields": [
        {
          "id": "currentInterestRate",
          "type": "slider",
          "label": "",
          "required": true,
          "validation": {
            "min": 1,
            "max": 15
          }
        }
      ]
    },

    {
      "id": "credit-score",
      "title": "Estimated credit score?",
      "description": "Checking won't impact your score.",
      "fields": [
        {
          "id": "creditScore",
          "type": "radio",
          "label": "",
          "required": true,
          "options": [
            { "value": "excellent", "label": "Excellent (720+)" },
            { "value": "good", "label": "Good (680–719)" },
            { "value": "fair", "label": "Fair (620–679)" },
            { "value": "poor", "label": "Poor (580–619)" }
          ]
        }
      ]
    },

    {
      "id": "employment-status",
      "title": "What's your employment status?",
      "description": "This helps lenders evaluate your application.",
      "skipIf": {
        "checkStepId": "loan-type",
        "checkFieldId": "loanType",
        "whenValues": ["home-equity-heloc"]
      },
      "fields": [
        {
          "id": "employmentStatus",
          "type": "radio",
          "label": "",
          "required": true,
          "autoForward": true,
          "options": [
            { "value": "employed", "label": "Employed" },
            { "value": "self-employed", "label": "Self-Employed" },
            { "value": "retired", "label": "Retired" },
            { "value": "unemployed", "label": "Unemployed" }
          ]
        }
      ]
    },

    {
      "id": "military-service",
      "title": "Served in the military?",
      "description": "Veterans qualify for $0-down programs.",
      "fields": [
        {
          "id": "veteranStatus",
          "type": "radio",
          "label": "",
          "required": true,
          "options": [
            { "value": "yes", "label": "YES" },
            { "value": "no", "label": "NO" }
          ]
        }
      ]
    },

    {
      "id": "contact",
      "title": "Ready to see your matches?",
      "description": "Your data is safe and secure. Match Engine",
      "fields": [
        {
          "id": "firstName",
          "type": "text",
          "label": "First Name",
          "placeholder": "John",
          "required": true
        },
        {
          "id": "lastName",
          "type": "text",
          "label": "Last Name",
          "placeholder": "Doe",
          "required": true
        },
        {
          "id": "email",
          "type": "email",
          "label": "Email",
          "placeholder": "john.doe@email.com",
          "required": true
        },
        {
          "id": "phone",
          "type": "tel",
          "label": "Phone Number",
          "placeholder": "(555) 123-4567",
          "required": true
        }
      ]
    }
  ]
}
